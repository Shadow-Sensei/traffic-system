#include <WiFi.h>
#include <WebServer.h>

const char* ssid = "AmbulanceSystem";
const char* password = "12345678";

WebServer server(80);

void handleRoot(){

server.send(200,"text/plain","ESP32 Server Running");

}

void handlePacket(){

String packet = server.arg("plain");

Serial.println("Packet received:");
Serial.println(packet);

server.send(200,"text/plain","Packet received");

}

void setup(){

Serial.begin(115200);

WiFi.softAP(ssid,password);

Serial.print("ESP32 IP: ");
Serial.println(WiFi.softAPIP());

server.on("/",handleRoot);
server.on("/packet",HTTP_POST,handlePacket);

server.begin();

Serial.println("Server started");

}

void loop(){

server.handleClient();

}